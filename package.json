{
  "name": "micro-bots",
  "version": "1.0.0",
  "description": "",
  "scripts": {
    "lint": "npm run lint:prettier && npm run lint:eslint",
    "lint:prettier": "prettier --check .",
    "lint:prettier-fix": "prettier --write .",
    "lint:eslint": "eslint src",
    "test": "jest",
    "deploy:dev": "DOTENV_CONFIG_PATH=.env.local NODE_OPTIONS='-r dotenv/config' serverless deploy --stage dev",
    "deploy:prod": "NODE_OPTIONS='-r dotenv/config' serverless deploy",
    "invoke": "DOTENV_CONFIG_PATH=.env.local NODE_OPTIONS='-r dotenv/config' serverless invoke local -f $npm_config_function"
  },
  "dependencies": {
    "@aws-sdk/client-eventbridge": "3.1038.0",
    "@slack/web-api": "6.13.0",
    "axios": "1.15.2",
    "dayjs": "1.11.20",
    "dayjs-business-time": "1.0.4",
    "form-data": "4.0.5",
    "jspdf": "4.2.1",
    "pdf-lib": "1.17.1"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/aws-lambda": "8.10.161",
    "@types/jest": "30.0.0",
    "@types/node": "24.12.2",
    "dotenv": "17.4.2",
    "esbuild": "0.28.0",
    "eslint": "10.2.1",
    "eslint-plugin-jest": "29.15.2",
    "jest": "30.3.0",
    "jest-file-snapshot": "0.7.0",
    "mockdate": "3.0.5",
    "prettier": "3.8.3",
    "serverless": "4.35.0",
    "serverless-esbuild": "1.57.1",
    "serverless-prune-plugin": "2.1.0",
    "ts-jest": "29.4.9",
    "typescript": "5.9.3",
    "typescript-eslint": "8.59.1"
  }
}
